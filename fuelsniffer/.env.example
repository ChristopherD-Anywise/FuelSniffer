# Copy to .env and fill in real values — never commit .env to git

# Database
DB_PASSWORD=changeme

# QLD Fuel Price API — register at https://www.fuelpricesqld.com.au
# Receive token by email after accepting the Limited Use Licence Terms
QLD_API_TOKEN=your_token_here

# healthchecks.io dead-man's-switch — create a check at https://healthchecks.io
# Set period=15min, grace=5min. Copy the ping URL here.
# Leave blank to disable external health monitoring during local development.
HEALTHCHECKS_PING_URL=

# Database connection (used by app container and local drizzle-kit commands)
DATABASE_URL=postgresql://fuelsniffer:changeme@localhost:5432/fuelsniffer
